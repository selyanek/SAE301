{
  "id": "sae301-tests",
  "version": "2.0",
  "name": "SAE301 Tests",
  "url": "http://localhost",
  "tests": [
    {
      "id": "test-etudiant-completer-absence",
      "name": "Étudiant - Compléter absence avec justificatif",
      "commands": [
        {
          "command": "open",
          "target": "/public/index.php",
          "value": ""
        },
        {
          "command": "executeScript",
          "target": "document.getElementById('identifiant').value = 'dilara.simsek'; document.getElementById('identifiant').dispatchEvent(new Event('input', {bubbles:true}));",
          "value": ""
        },
        {
          "command": "executeScript",
          "target": "document.getElementById('mot_de_passe').value = '7c45d6ca0f'; document.getElementById('mot_de_passe').dispatchEvent(new Event('input', {bubbles:true}));",
          "value": ""
        },
        {
          "command": "click",
          "target": "id=submit-btn",
          "value": ""
        },
        {
          "command": "waitForElementPresent",
          "target": "linkText=Mon Profil",
          "value": ""
        },
        {
          "command": "click",
          "target": "linkText=Gérer des absences",
          "value": ""
        },
        {
          "command": "waitForElementPresent",
          "target": "linkText=Soumettre un nouveau justificatif",
          "value": ""
        },
        {
          "command": "click",
          "target": "linkText=Soumettre un nouveau justificatif",
          "value": ""
        },
        {
          "command": "waitForElementPresent",
          "target": "id=date_start",
          "value": ""
        },
        {
          "command": "executeScript",
          "target": "document.getElementById('date_start').value = '2026-03-16T08:00'; document.getElementById('date_start').dispatchEvent(new Event('input', {bubbles:true}));",
          "value": ""
        },
        {
          "command": "executeScript",
          "target": "document.getElementById('date_end').value = '2026-03-18T17:00'; document.getElementById('date_end').dispatchEvent(new Event('input', {bubbles:true}));",
          "value": ""
        },
        {
          "command": "executeScript",
          "target": "document.getElementById('motif').value = 'Maladie'; document.getElementById('motif').dispatchEvent(new Event('input', {bubbles:true}));",
          "value": ""
        },
        {
          "command": "type",
          "target": "id=fileInput",
          "value": "/path/to/justificatif.pdf"
        },
        {
          "command": "click",
          "target": "id=submitBtn",
          "value": ""
        },
        {
          "command": "waitForElementPresent",
          "target": "css=.message.success",
          "value": ""
        },
        {
          "command": "assertText",
          "target": "css=.message.success",
          "value": "Votre justificatif a été envoyé avec succès !"
        }
      ]
    },
    {
      "id": "test-secretaire-upload-csv",
      "name": "Secrétaire - Simulation envoi fichier CSV",
      "commands": [
        {
          "command": "open",
          "target": "/public/index.php",
          "value": ""
        },
        {
          "command": "executeScript",
          "target": "document.getElementById('identifiant').value = 'delphine.milice'; document.getElementById('identifiant').dispatchEvent(new Event('input', {bubbles:true}));",
          "value": ""
        },
        {
          "command": "executeScript",
          "target": "document.getElementById('mot_de_passe').value = 'motdepasse123'; document.getElementById('mot_de_passe').dispatchEvent(new Event('input', {bubbles:true}));",
          "value": ""
        },
        {
          "command": "click",
          "target": "id=submit-btn",
          "value": ""
        },
        {
          "command": "waitForElementPresent",
          "target": "linkText=Envoie des absences",
          "value": ""
        },
        {
          "command": "click",
          "target": "linkText=Envoie des absences",
          "value": ""
        },
        {
          "command": "waitForElementPresent",
          "target": "id=fileInput",
          "value": ""
        },
        {
          "command": "type",
          "target": "id=fileInput",
          "value": "/path/to/data/CSV/BUT1-240122-240223_anonymise.CSV"
        },
        {
          "command": "click",
          "target": "id=submitBtn",
          "value": ""
        },
        {
          "command": "waitForElementPresent",
          "target": "xpath=//h1",
          "value": ""
        },
        {
          "command": "assertText",
          "target": "xpath=//h1",
          "value": "Import terminé avec succès"
        }
      ]
    },
    {
      "id": "test-etudiant-changer-mdp",
