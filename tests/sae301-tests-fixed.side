        {
          "command": "executeScript",
          "target": "document.getElementById('new_password').value = 'newpassword456'; document.getElementById('new_password').dispatchEvent(new Event('input', {bubbles:true}));",
          "value": ""
        },
        {
          "command": "executeScript",
          "target": "document.getElementById('confirm_password').value = 'newpassword456'; document.getElementById('confirm_password').dispatchEvent(new Event('input', {bubbles:true}));",
