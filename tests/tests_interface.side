{
  "id": "sae301-tests",
  "version": "2.0",
  "name": "SAE301 Tests",
  "url": "http://localhost",
  "tests": [
    {
      "id": "test-etudiant-completer-absence",
      "name": "Étudiant - Compléter absence avec justificatif",
      "commands": [
        {
          "command": "open",
          "target": "/index.php",
          "value": ""
        },
        {
          "command": "type",
          "target": "id=identifiant",
          "value": "dilara.simsek"
        },
        {
          "command": "type",
          "target": "id=mot_de_passe",
          "value": "motdepasse123"
        },
        {
          "command": "click",
          "target": "id=login-button",
          "value": ""
        },
        {
          "command": "waitForElementPresent",
          "target": "link=Consulter vos justificatifs",
          "value": ""
        },
        {
          "command": "click",
          "target": "link=Consulter vos justificatifs",
          "value": ""
        },
        {
          "command": "waitForElementPresent",
          "target": "css=.btn-resoumettre",
          "value": ""
        },
        {
          "command": "click",
          "target": "css=.btn-resoumettre",
          "value": ""
        },
        {
          "command": "waitForElementPresent",
          "target": "id=date_start",
          "value": ""
        },
        {
          "command": "type",
          "target": "id=date_start",
          "value": "2026-03-16T08:00"
        },
        {
          "command": "type",
          "target": "id=date_end",
          "value": "2026-03-18T17:00"
        },
        {
          "command": "type",
          "target": "id=motif",
          "value": "Maladie"
        },
        {
          "command": "type",
          "target": "id=fileInput",
          "value": "/path/to/justificatif.pdf"
        },
        {
          "command": "click",
          "target": "id=submitBtn",
          "value": ""
        },
        {
          "command": "waitForElementPresent",
          "target": "id=message",
          "value": ""
        },
        {
          "command": "assertText",
          "target": "id=message",
          "value": "Fichier téléchargé avec succès"
        }
      ]
    },
    {
      "id": "test-secretaire-upload-csv",
      "name": "Secrétaire - Simulation envoi fichier CSV",
      "commands": [
        {
          "command": "open",
          "target": "/index.php",
          "value": ""
        },
        {
          "command": "type",
          "target": "id=identifiant",
          "value": "delphine.milice"
        },
        {
          "command": "type",
          "target": "id=mot_de_passe",
          "value": "password123"
        },
        {
          "command": "click",
          "target": "id=login-button",
          "value": ""
        },
        {
          "command": "waitForElementPresent",
          "target": "link=Envoie des absences",
          "value": ""
        },
        {
          "command": "click",
          "target": "link=Envoie des absences",
          "value": ""
        },
        {
          "command": "waitForElementPresent",
          "target": "id=uploadForm",
          "value": ""
        },
        {
          "command": "type",
          "target": "id=fileInput",
          "value": "/path/to/data/CSV/BUT1-240122-240223_anonymise.CSV"
        },
        {
          "command": "click",
          "target": "id=submitBtn",
          "value": ""
        },
        {
          "command": "waitForElementPresent",
          "target": "css=.success-message",
          "value": ""
        },
        {
          "command": "assertText",
          "target": "css=.success-message",
          "value": "Fichier CSV importé avec succès"
        }
      ]
    },
    {
      "id": "test-etudiant-changer-mdp",
      "name": "Étudiant - Changer mot de passe",
      "commands": [
        {
          "command": "open",
          "target": "/index.php",
          "value": ""
        },
        {
          "command": "type",
          "target": "id=identifiant",
          "value": "dilara.simsek"
        },
        {
          "command": "type",
          "target": "id=mot_de_passe",
          "value": "motdepasse123"
        },
        {
          "command": "click",
          "target": "id=login-button",
          "value": ""
        },
        {
          "command": "waitForElementPresent",
          "target": "link=Mon profil",
          "value": ""
        },
        {
          "command": "click",
          "target": "link=Mon profil",
          "value": ""
        },
        {
          "command": "waitForElementPresent",
          "target": "id=old_password",
          "value": ""
        },
        {
          "command": "type",
          "target": "id=old_password",
          "value": "motdepasse123"
        },
        {
          "command": "type",
          "target": "id=new_password",
          "value": "newpassword456"
        },
        {
          "command": "type",
          "target": "id=confirm_password",
          "value": "newpassword456"
        },
        {
          "command": "click",
          "target": "css=.form-ajax button[type='submit']",
          "value": ""
        },
        {
          "command": "waitForElementPresent",
          "target": "css=.success",
          "value": ""
        },
        {
          "command": "assertText",
          "target": "css=.success",
          "value": "Mot de passe changé avec succès"
        }
      ]
    },
    {
      "id": "test-professeur-filtrer-absences",
