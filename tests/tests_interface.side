{
  "id": "sae301-tests",
  "version": "2.0",
  "name": "SAE301 Tests",
  "url": "http://localhost",
  "tests": [
    {
      "id": "test-etudiant-completer-absence",
      "name": "Étudiant - Compléter absence avec justificatif",
      "commands": [
        {
          "command": "open",
          "target": "/index.php",
          "value": ""
        },
        {
          "command": "type",
          "target": "id=username",
          "value": "dilara.simsek"
        },
        {
          "command": "type",
          "target": "id=password",
          "value": "motdepasse123"
        },
        {
          "command": "click",
          "target": "id=login-button",
          "value": ""
        },
        {
          "command": "waitForElementPresent",
          "target": "linkText=Mon Profil",
          "value": ""
        },
        {
          "command": "click",
          "target": "linkText=Mon Profil",
          "value": ""
        },
        {
          "command": "waitForElementPresent",
          "target": "id=resoumettre-absence",
          "value": ""
        },
        {
          "command": "click",
          "target": "id=resoumettre-absence",
          "value": ""
        },
        {
          "command": "waitForElementPresent",
          "target": "id=date-debut",
          "value": ""
        },
        {
          "command": "type",
          "target": "id=date-debut",
          "value": "2026-03-16"
        },
        {
          "command": "type",
          "target": "id=heure-debut",
          "value": "08:00"
        },
        {
          "command": "type",
          "target": "id=date-fin",
          "value": "2026-03-18"
        },
        {
          "command": "type",
          "target": "id=heure-fin",
          "value": "17:00"
        },
        {
          "command": "type",
          "target": "id=justificatif",
          "value": "Maladie"
        },
        {
          "command": "click",
          "target": "id=upload-file",
          "value": ""
        },
        {
          "command": "type",
          "target": "id=file-input",
          "value": "/path/to/justificatif.pdf"
        },
        {
          "command": "click",
          "target": "id=submit-absence",
          "value": ""
        },
        {
          "command": "waitForElementPresent",
          "target": "id=validation-message",
          "value": ""
        },
        {
          "command": "assertText",
          "target": "id=validation-message",
          "value": "Absence soumise avec succès"
        }
      ]
    },
    {
      "id": "test-secretaire-upload-csv",
