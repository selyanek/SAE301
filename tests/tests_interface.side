        {
          "command": "click",
          "target": "linkText=Importer CSV",
          "value": ""
        },
        {
          "command": "waitForElementPresent",
          "target": "id=csv-upload",
          "value": ""
        },
        {
          "command": "type",
          "target": "id=csv-upload",
          "value": "/path/to/data/CSV/BUT1-240122-240223_anonymise.CSV"
        },
        {
          "command": "click",
          "target": "id=upload-button",
          "value": ""
        },
        {
          "command": "waitForElementPresent",
          "target": "id=validation-message",
          "value": ""
        },
        {
          "command": "assertText",
          "target": "id=validation-message",
          "value": "Fichier CSV importé avec succès"
        }
      ]
    },
